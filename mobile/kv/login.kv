<LoginScreen>:
    MDFloatLayout:
        MDCard:
            size_hint: 0.85, 0.6
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            elevation: 10
            padding: 25
            spacing: 20
            orientation: "vertical"
            
            MDBoxLayout:
                orientation: "vertical"
                spacing: 20
                padding: 20
                
                MDLabel:
                    text: "Ventas App"
                    font_style: "H4"
                    halign: "center"
                    size_hint_y: None
                    height: self.texture_size[1]
                    
                MDLabel:
                    text: "Iniciar Sesión"
                    font_style: "H6"
                    halign: "center"
                    size_hint_y: None
                    height: self.texture_size[1]
                    
                Widget:
                    size_hint_y: None
                    height: 20
                    
                MDTextField:
                    id: username
                    hint_text: "Usuario"
                    icon_right: "account"
                    size_hint_y: None
                    height: 48
                    
                MDTextField:
                    id: password
                    hint_text: "Contraseña"
                    icon_right: "key"
                    password: True
                    size_hint_y: None
                    height: 48
                    
                Widget:
                    size_hint_y: None
                    height: 20
                    
                MDRaisedButton:
                    text: "INGRESAR"
                    size_hint_x: 1
                    pos_hint: {"center_x": 0.5}
                    on_release: root.login()
